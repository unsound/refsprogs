Package: refs-fuse
Section: otherosfs
Architecture: linux-any kfreebsd-any
Depends:
 ${misc:Depends},
 ${shlibs:Depends},
 librefs13 (= ${binary:Version}),
 fuse3 [linux-any],
 fuse4bsd [kfreebsd-any]
#Provides: ${refsprogs:Provides}
Description: Read-only ReFS FUSE driver,
 refs-fuse uses FUSE (Filesystem in Userspace) to provide support for the ReFS
 filesystem used by recent versions of Microsoft Windows.

Package: refsprogs
Section: otherosfs
Architecture: linux-any kfreebsd-any
Depends:
 ${misc:Depends},
 ${shlibs:Depends},
 librefs13 (= ${binary:Version}),
#Provides: ${refsprogs:Provides}
Description: Read-only ReFS progs,
 refsprogs includes 'refls', 'refcat', useful for listing and retrieving data
 from ReFS volumes, 'refsimage' for capturing an image of the ReFS filesystem
 and 'redb' / 'refsinfo' which allows access to the metadata of the filesystem
 for debugging and development.

