#!/usr/bin/make -f
# -*- makefile -*-

include /usr/share/dpkg/default.mk

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

SHELL := sh -e

DEB_HOST_ARCH_OS ?= $(shell dpkg-architecture -qDEB_HOST_ARCH_OS)
DEB_HOST_MULTIARCH ?= $(shell dpkg-architecture -qDEB_HOST_MULTIARCH)

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

SONAME = $(shell objdump -p debian/tmp/lib/*/librefs.so.*.* | awk -Fso. '/SONAME/ { print $$2 }')

ifeq ($(DEB_HOST_ARCH_OS), linux)
CONFIGURE_FLAGS = --enable-posix-acls
endif

upstream:
	lynx -dump http://github.com/unsound/refsprogs/releases > debian/local/changelog

%:
	dh ${@}

override_dh_auto_configure:
	dh_auto_configure -- \
		--exec-prefix=/ \
		--enable-mount-helper \
		--disable-ldconfig \
		$(CONFIGURE_FLAGS)

override_dh_auto_install:
	dh_auto_install

	# moving shlib to /
	mkdir -p debian/tmp/lib/$(DEB_HOST_MULTIARCH)
	mv debian/tmp/usr/lib/$(DEB_HOST_MULTIARCH)/*.so.* debian/tmp/lib/$(DEB_HOST_MULTIARCH)

	# adding initramfs-tools integration
	install -D -m 0755 debian/local/refs-fuse.hook debian/refs-fuse/usr/share/initramfs-tools/hooks/refs_fuse
	install -D -m 0755 debian/local/refs-fuse.local-premount debian/refs-fuse/usr/share/initramfs-tools/scripts/local-premount/refs_fuse
	install -D -m 0755 debian/local/refs-fuse.local-bottom debian/refs-fuse/usr/share/initramfs-tools/scripts/local-bottom/refs_fuse

	# adding hal policy
	# not used by Debian anymore
	#install -D -m 0644 debian/local/25-refs-fuse-policy.fdi debian/refs-fuse/usr/share/hal/fdi/policy/10osvendor/25-refs-fuse-policy.fdi

	# removing unused files
	rm -f debian/tmp/usr/lib/*/*.la

	# removing rpath
	for _PROGRAM in \
		bin/redb \
		bin/refs-fuse \
		bin/refscat \
		bin/refsimage \
		bin/refsinfo \
		bin/refslabel \
		bin/refsls; \
	do \
		echo $${_PROGRAM}; \
		chrpath --delete debian/tmp/$${_PROGRAM}; \
	done

	# Copy the sources for the Linux kernel driver to /usr/src to be included in refs-dkms.
	mkdir -p $(CURDIR)/debian/tmp/usr/src/refs-$(DEB_VERSION_UPSTREAM)/scripts
	cp $(CURDIR)/targets/linux/*.[ch] $(CURDIR)/targets/linux/Kbuild $(CURDIR)/targets/linux/Makefile $(CURDIR)/debian/tmp/usr/src/refs-$(DEB_VERSION_UPSTREAM)/

	# Generate the post-build script.
	echo '#!/bin/sh' > '$(CURDIR)/debian/tmp/usr/src/refs-$(DEB_VERSION_UPSTREAM)/scripts/refs-dkms-postbuild.sh'
	echo '' >> '$(CURDIR)/debian/tmp/usr/src/refs-$(DEB_VERSION_UPSTREAM)/scripts/refs-dkms-postbuild.sh'
	echo 'if [ $$# -ne 2 ]; then echo "usage: $$0 <base dir> <kernel/arch dir>"; exit 1; fi' >> '$(CURDIR)/debian/tmp/usr/src/refs-$(DEB_VERSION_UPSTREAM)/scripts/refs-dkms-postbuild.sh'
	echo '' >> '$(CURDIR)/debian/tmp/usr/src/refs-$(DEB_VERSION_UPSTREAM)/scripts/refs-dkms-postbuild.sh'
	echo 'cp "$${1}/build/Module.symvers" "$${1}/$${2}/"' >> '$(CURDIR)/debian/tmp/usr/src/refs-$(DEB_VERSION_UPSTREAM)/scripts/refs-dkms-postbuild.sh'
	chmod a+x '$(CURDIR)/debian/tmp/usr/src/refs-$(DEB_VERSION_UPSTREAM)/scripts/refs-dkms-postbuild.sh'

override_dh_dkms:
	# Generate a DKMS configuration file for the refs driver.
	echo 'PACKAGE_NAME=refs' > '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'PACKAGE_VERSION=$(DEB_VERSION_UPSTREAM)' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'PACKAGE_CONFIG=/etc/dkms/refs.conf' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'NO_WEAK_MODULES="yes"' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'if [ -f \$$kernel_source_dir/.config ]; then' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo '    . \$$kernel_source_dir/.config' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo '    if [ "\$$CONFIG_PREEMPT_RT" = "y" ]; then' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo '        BUILD_EXCLUSIVE_KERNEL="NOT ON PREEMPT_RT"' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo '    fi' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'fi' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'POST_BUILD="scripts/refs-dkms-postbuild.sh \"\$${dkms_tree}/\$${PACKAGE_NAME}/\$${PACKAGE_VERSION}\" \"\$${kernelver}/\$${arch}\""' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'AUTOINSTALL="yes"' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'MAKE[0]="make KDIR=\"\$${kernel_source_dir}\""' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'STRIP[0]="\$$(' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo '  [[ -r \$${PACKAGE_CONFIG} ]] \\' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo '  && source \$${PACKAGE_CONFIG} \\' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo '  && shopt -q -s extglob \\' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo '  && echo -n no' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo ')"' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'BUILT_MODULE_NAME[0]="refs"' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'BUILT_MODULE_LOCATION[0]=""' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'
	echo 'DEST_MODULE_LOCATION[0]="/extra"' >> '$(CURDIR)/debian/tmp/refs-dkms.dkms'

	dh_dkms
	rm -f '$(CURDIR)/debian/tmp/refs-dkms.dkms'

#override_dh_gencontrol:
#	dh_gencontrol -- -Vrefsprogs:Provides="librefs$(SONAME)" -Vrefsprogs-udeb:Provides="librefs-udeb$(SONAME)"

override_dh_installchangelogs:
	dh_installchangelogs debian/local/changelog

override_dh_link:
	rm -rf debian/librefs-dev/usr/share/doc

	# correcting symlink target
	dh_link -plibrefs-dev lib/$(DEB_HOST_MULTIARCH)/$$(basename $$(readlink debian/tmp/usr/lib/$(DEB_HOST_MULTIARCH)/librefs.so)) usr/lib/$(DEB_HOST_MULTIARCH)/librefs.so

	dh_link --remaining-packages

override_dh_makeshlibs:
	dh_makeshlibs --add-udeb=refsprogs-udeb -Vlibrefs$(SONAME)

.PHONY: override_dh_auto_configure override_dh_auto_install \
	override_dh_installchangelogs \
	override_dh_link override_dh_makeshlibs
